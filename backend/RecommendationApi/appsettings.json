{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "System": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AlbumsFilePath": "albums.json",
  "Cors": {
    "AllowedOrigins": [
      "https://moodalbum.com",
      "https://www.moodalbum.com",
      "http://localhost:4200",
      "http://localhost:5240"
    ],
    "AllowedMethods": [
      "GET",
      "POST",
      "PUT",
      "DELETE",
      "OPTIONS"
    ],
    "AllowedHeaders": [
      "*"
    ]
  },
  "ReverseProxy": {
    "KnownProxies": [
      "127.0.0.1",
      "::1"
    ]
  }
}