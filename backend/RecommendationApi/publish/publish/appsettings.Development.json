{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200"
    ],
    "AllowedMethods": [
      "GET",
      "POST"
    ],
    "AllowedHeaders": [
      "Content-Type",
      "X-Anonymous-Id"
    ]
  },
  "ReverseProxy": {
    "KnownProxies": [
      "127.0.0.1",
      "::1"
    ]
  }
}
