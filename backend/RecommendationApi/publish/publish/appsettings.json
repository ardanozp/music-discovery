{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "System": "Warning"
    }
  },
  "AllowedHosts": "api.musicdiscovery.example;musicdiscovery.example;localhost;127.0.0.1",
  "AlbumsFilePath": "albums.json",
  "Cors": {
    "AllowedOrigins": [
      "https://musicdiscovery.example"
    ],
    "AllowedMethods": [
      "GET",
      "POST"
    ],
    "AllowedHeaders": [
      "Content-Type",
      "X-Anonymous-Id"
    ]
  },
  "ReverseProxy": {
    "KnownProxies": [
      "127.0.0.1",
      "::1"
    ]
  }
}
